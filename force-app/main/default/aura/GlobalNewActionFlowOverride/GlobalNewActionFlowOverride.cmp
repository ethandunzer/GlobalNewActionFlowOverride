<aura:component
	controller="GlobalNewActionFlowOverrideController"
	access="global"
	implements="lightning:actionOverride,force:hasSObjectName,flexipage:availableForAllPageTypes"
>
	<aura:attribute name="sObjectName" type="String" />
	<aura:attribute name="flowApiName" type="String" />
	<aura:attribute name="newRecordIdOutputName" type="String" default="NewRecordId" />

	<aura:handler name="init" value="{!this}" action="{!c.doInit}" />

	<div class="flow-page">
		<div class="flow-shell slds-card">
			<lightning:flow aura:id="newActionFlow" onstatuschange="{!c.handleStatusChange}" />
		</div>
	</div>
</aura:component>